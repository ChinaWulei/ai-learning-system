APP_ENV=development
LLM_PROVIDER=mock
LLM_MODEL=mock-learning-model
LLM_API_KEY=
LLM_BASE_URL=

# Gemini chat example:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your-gemini-key
# LLM_API_KEY can also be used instead of GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-preview-tts
GEMINI_TTS_VOICE=Sulafat
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
USE_BGE=false
JAVA_BASE_URL=http://localhost:8080
JAVA_INTERNAL_TOKEN=change-me

